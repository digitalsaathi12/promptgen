# Project Setup
PROJECT_NAME="The Digital Saathi"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Security & JWT
SECRET_KEY="saathi-super-secret-key-for-local-development-only-xyz"
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Databases (Defaults to sqlite if postgres is not available, but postgres url is configured)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/digitalsaathi"
REDIS_URL="redis://localhost:6379/0"

# Celery (Set CELERY_TASK_ALWAYS_EAGER=True to run background tasks synchronously for local testing without Celery/Redis)
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_TASK_ALWAYS_EAGER=True

# Google OAuth
GOOGLE_CLIENT_ID="mock-google-client-id"

# Supabase Storage
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_BUCKET="digital-saathi-assets"

# AI Provider API Keys
OPENAI_API_KEY=""
GEMINI_API_KEY="AQ.Ab8RN6K90Hk7ZOTyOQK1Eu7epx9LgFvnQmLrFZLZnPwczyY6sQ"
CLAUDE_API_KEY=""
OLLAMA_API_URL="http://localhost:11434"

# Image Generation API Keys
STABILITY_API_KEY=""
FLUX_API_KEY=""

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
