# Project Setup
PROJECT_NAME="The Digital Saathi"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Security & JWT
SECRET_KEY="replace-with-a-very-secure-random-secret-key-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Databases
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/digitalsaathi"
REDIS_URL="redis://redis:6379/0"

# Celery
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"
CELERY_TASK_ALWAYS_EAGER=False

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Supabase Storage
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_BUCKET="digital-saathi-assets"

# AI Provider API Keys (leave empty to use mock/fallback responses)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
CLAUDE_API_KEY=""
OLLAMA_API_URL="http://localhost:11434"

# Image Generation API Keys
STABILITY_API_KEY=""
FLUX_API_KEY=""

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
